{
  "name": "mirror-defense-duel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite client --port 3100",
    "build": "tsc -p server/tsconfig.json && vite build client"
  },
  "dependencies": {
    "colyseus": "^0.16.0",
    "@colyseus/core": "^0.16.0",
    "@colyseus/auth": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17"
  }
}
